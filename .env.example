# Local file store (data/*.json) is used when Supabase URL + key are unset.

# Shared Supabase project — app tables live in the `todooz` schema (not public).
NEXT_PUBLIC_SUPABASE_URL=
# Prefer the publishable key; legacy anon key also works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: only needed for admin/migrations, not used by the app runtime.
# SUPABASE_SERVICE_ROLE_KEY=
